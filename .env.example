DATABASE_URL=postgresql://postgres:123456@localhost:5432/neondb
# Required: application will not start without PostgreSQL DATABASE_URL
# Optional: read-only source for category import (pnpm db:import-categories / db:import-category-images)
STEPMOTECH_DATABASE_URL=
AUTH_SECRET=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
APP_URL=http://localhost:5100
AUTH_URL=http://localhost:5100
NEXTAUTH_URL=http://localhost:5100
CORS_ALLOWED_ORIGINS=http://localhost:5000
FRONT_CALLBACK_URL=http://localhost:5000/auth/callback
NEXT_PUBLIC_SITE_URL=http://localhost:5100

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Email (mock mode — logs only; no outbound provider configured)
EMAIL_FROM=STEPMOTECH <noreply@stepmotech.online>

# Aliyun OSS Configuration (machrio bucket, us-west-1)
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_BUCKET=machrio
ALIYUN_OSS_ENDPOINT=https://oss-us-west-1.aliyuncs.com
ALIYUN_OSS_REGION=oss-us-west-1
ALIYUN_OSS_DOMAIN=https://machrio.oss-us-west-1.aliyuncs.com
NEXT_PUBLIC_ALIYUN_OSS_DOMAIN=https://machrio.oss-us-west-1.aliyuncs.com

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

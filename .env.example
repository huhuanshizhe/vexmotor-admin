DATABASE_URL=postgresql://postgres:123456@localhost:5432/neondb
AUTH_SECRET=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Admin console + API (NextAuth also reads AUTH_URL / NEXTAUTH_URL — set automatically from ADMIN_URL)
ADMIN_URL=http://localhost:5100

# Customer storefront (CORS, email links, OAuth callback)
SITE_URL=http://localhost:5000

# Web UI strings manifest URL for admin sync (defaults to SITE_URL/api/ui-strings/manifest)
# WEB_UI_STRINGS_MANIFEST_URL=http://localhost:5000/api/ui-strings/manifest

# Optional: multiple storefront origins, comma-separated (defaults to SITE_URL)
# CORS_ALLOWED_ORIGINS=http://localhost:5000,https://staging.example.com

# Optional: override OAuth callback (defaults to SITE_URL/auth/callback)
# FRONT_CALLBACK_URL=http://localhost:5000/auth/callback

# Airwallex (legacy unpaid orders only — new Credit Card checkout uses Stripe)
AIRWALLEX_SANDBOX_CLIENT_ID=your_sandbox_client_id
AIRWALLEX_SANDBOX_API_KEY=your_sandbox_api_key
AIRWALLEX_LIVE_CLIENT_ID=your_live_client_id
AIRWALLEX_LIVE_API_KEY=your_live_api_key

# Stripe
STRIPE_SANDBOX_SECRET_KEY=sk_test_your_secret_key
STRIPE_SANDBOX_PUBLIC_KEY=pk_test_your_public_key
STRIPE_LIVE_SECRET_KEY=sk_live_your_secret_key
STRIPE_LIVE_PUBLIC_KEY=pk_live_your_public_key

# Email (SMTP — WeCom/Exmail; set EMAIL_MOCK=true to skip outbound sends in dev)
EMAIL_FROM=STEPMOTECH <noreply@stepmotech.online>
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@stepmotech.online
SMTP_PASS=your_smtp_password_or_app_token
# EMAIL_MOCK=true

# Aliyun OSS Configuration (machrio bucket, us-west-1)
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_BUCKET=machrio
ALIYUN_OSS_ENDPOINT=https://oss-us-west-1.aliyuncs.com
ALIYUN_OSS_REGION=oss-us-west-1
ALIYUN_OSS_DOMAIN=https://machrio.oss-us-west-1.aliyuncs.com

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Text LLM (OpenAI-compatible, used for translation)
TEXT_API_KEY=your_text_api_key
TEXT_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
TEXT_MODEL=qwen3.7-plus

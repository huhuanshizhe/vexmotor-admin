{
  "name": "vexmotor-admin",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "node scripts/dev-server.mjs --db",
    "dev:db": "node scripts/dev-server.mjs --db",
    "build": "next build",
    "start": "next start -p 5100",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "eslint . && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/server/db/seed.ts",
    "db:migrate-admins": "tsx scripts/migrate-admin-users.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@types/ali-oss": "^6.23.3",
    "ali-oss": "^6.23.0",
    "antd": "^6.4.3",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.5",
    "jose": "^6.0.11",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.31",
    "postgres": "^3.4.7",
    "proxy-agent": "^6.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.4",
    "stripe": "^17.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.34.0",
    "eslint-config-next": "^16.2.6",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "next": "16"
      }
    }
  }
}

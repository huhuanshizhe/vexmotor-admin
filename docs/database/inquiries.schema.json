{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/database/inquiries.schema.json",
  "title": "inquiries",
  "description": "询价主表。支持游客或登录用户提交。productId 必填，userId 可空。后台根据 status 跟踪处理进度。",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "productId", "fullName", "email", "message", "status", "createdAt", "updatedAt"],
  "properties": {
    "id": {"type": "string", "format": "uuid"},
    "productId": {"type": "string", "format": "uuid", "description": "关联 products.id"},
    "userId": {"type": ["string", "null"], "format": "uuid", "description": "关联 users.id"},
    "fullName": {"type": "string", "maxLength": 150},
    "email": {"type": "string", "format": "email", "maxLength": 320},
    "phone": {"type": ["string", "null"], "maxLength": 50},
    "company": {"type": ["string", "null"], "maxLength": 150},
    "country": {"type": ["string", "null"], "maxLength": 100},
    "message": {"type": "string"},
    "status": {"type": "string", "enum": ["new", "contacted", "quoted", "closed"]},
    "sourcePageUrl": {"type": ["string", "null"], "format": "uri"},
    "handledBy": {"type": ["string", "null"], "format": "uuid", "description": "关联后台处理人 users.id"},
    "handledAt": {"type": ["string", "null"], "format": "date-time"},
    "internalNote": {"type": ["string", "null"]},
    "createdAt": {"type": "string", "format": "date-time"},
    "updatedAt": {"type": "string", "format": "date-time"}
  }
}